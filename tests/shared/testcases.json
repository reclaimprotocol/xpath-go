[
  {
    "name": "Basic element selection",
    "html": "<html><body><div>Hello</div><p>World</p></body></html>",
    "xpath": "//div",
    "description": "Select all div elements",
    "category": "basic"
  },
  {
    "name": "Root element selection", 
    "html": "<html><head><title>Test</title></head><body><div>Content</div></body></html>",
    "xpath": "/html",
    "description": "Select root html element",
    "category": "basic"
  },
  {
    "name": "Child element selection",
    "html": "<html><body><div><p>Nested</p></div><p>Top level</p></body></html>",
    "xpath": "/html/body/p",
    "description": "Select direct child p elements of body",
    "category": "basic"
  },
  {
    "name": "Attribute selection", 
    "html": "<html><body><div id='test' class='highlight'>Content</div><div class='other'>Other</div></body></html>",
    "xpath": "//div[@id='test']",
    "description": "Select div with specific id",
    "category": "attributes"
  },
  {
    "name": "Attribute existence",
    "html": "<html><body><div id='test'>With ID</div><div>Without ID</div></body></html>",
    "xpath": "//div[@id]",
    "description": "Select divs that have an id attribute",
    "category": "attributes"
  },
  {
    "name": "Multiple attribute selection",
    "html": "<html><body><div id='test' class='highlight'>Both</div><div id='other'>ID only</div><div class='highlight'>Class only</div></body></html>",
    "xpath": "//div[@id and @class]",
    "description": "Select divs with both id and class attributes",
    "category": "attributes"
  },
  {
    "name": "Text content selection",
    "html": "<html><body><p>First</p><p>Second</p><p>Third</p></body></html>",
    "xpath": "//p[text()='Second']",
    "description": "Select element by exact text content",
    "category": "text"
  },
  {
    "name": "Text content existence",
    "html": "<html><body><p>Has text</p><p></p><p>Also has text</p></body></html>",
    "xpath": "//p[text()]",
    "description": "Select elements that have text content",
    "category": "text"
  },
  {
    "name": "Contains text function",
    "html": "<html><body><p>The quick brown fox</p><p>Lazy dog sleeping</p><p>Quick silver</p></body></html>",
    "xpath": "//p[contains(text(), 'quick')]",
    "description": "Select elements containing specific text (case sensitive)",
    "category": "text"
  },
  {
    "name": "Position-based selection",
    "html": "<html><body><ul><li>Item 1</li><li>Item 2</li><li>Item 3</li></ul></body></html>",
    "xpath": "//li[position()=2]",
    "description": "Select second list item",
    "category": "position"
  },
  {
    "name": "Last position selection",
    "html": "<html><body><ul><li>First</li><li>Middle</li><li>Last</li></ul></body></html>",
    "xpath": "//li[last()]",
    "description": "Select last list item",
    "category": "position"
  },
  {
    "name": "Numeric position selection",
    "html": "<html><body><ol><li>One</li><li>Two</li><li>Three</li><li>Four</li></ol></body></html>",
    "xpath": "//li[3]",
    "description": "Select third list item using numeric predicate",
    "category": "position"
  },
  {
    "name": "Descendant axis",
    "html": "<html><body><div><span><a href='#'>Link</a></span></div><a href='#'>Top link</a></body></html>",
    "xpath": "//div//a",
    "description": "Select anchor descendant of div",
    "category": "axes"
  },
  {
    "name": "Parent axis",
    "html": "<html><body><div><p id='child'>Child</p></div></body></html>",
    "xpath": "//p[@id='child']/parent::div",
    "description": "Select parent div of specific p element",
    "category": "axes"
  },
  {
    "name": "Following sibling axis",
    "html": "<html><body><div><h1>Title</h1><p>First para</p><p>Second para</p></div></body></html>",
    "xpath": "//h1/following-sibling::p",
    "description": "Select p elements that follow h1",
    "category": "axes"
  },
  {
    "name": "Preceding sibling axis",
    "html": "<html><body><div><p>Before</p><h2>Header</h2><p>After</p></div></body></html>",
    "xpath": "//h2/preceding-sibling::p",
    "description": "Select p elements that precede h2",
    "category": "axes"
  },
  {
    "name": "Self axis",
    "html": "<html><body><div id='target'>Self</div></body></html>",
    "xpath": "//div[@id='target']/self::div",
    "description": "Select the div element itself",
    "category": "axes"
  },
  {
    "name": "Complex predicate with OR",
    "html": "<html><body><div class='red'>Red</div><div class='blue'>Blue</div><div class='green'>Green</div></body></html>",
    "xpath": "//div[@class='red' or @class='blue']",
    "description": "Select divs with red OR blue class",
    "category": "complex"
  },
  {
    "name": "Multiple predicates",
    "html": "<html><body><div id='test' class='active'>Target</div><div id='other' class='active'>Other</div><div id='test'>Inactive</div></body></html>",
    "xpath": "//div[@id='test'][@class='active']",
    "description": "Select div with specific id AND class",
    "category": "complex"
  },
  {
    "name": "Nested predicates",
    "html": "<html><body><ul><li><span>First</span></li><li><span>Second</span></li></ul></body></html>",
    "xpath": "//li[span[text()='Second']]",
    "description": "Select li containing span with specific text",
    "category": "complex"
  },
  {
    "name": "Wildcard with predicate",
    "html": "<html><body><div class='highlight'>Div</div><p class='highlight'>Para</p><span>Span</span></body></html>",
    "xpath": "//*[@class='highlight']",
    "description": "Select all elements with specific class",
    "category": "wildcard"
  },
  {
    "name": "Union expression",
    "html": "<html><body><h1>Header</h1><p>Para</p><h2>Subheader</h2></body></html>",
    "xpath": "//h1 | //h2",
    "description": "Select both h1 and h2 elements",
    "category": "union"
  },
  {
    "name": "Attribute axis",
    "html": "<html><body><div id='test' class='highlight' data-value='123'>Content</div></body></html>",
    "xpath": "//div/@class",
    "description": "Select class attribute of div",
    "category": "attributes"
  },
  {
    "name": "All attributes",
    "html": "<html><body><input type='text' name='username' required /></body></html>",
    "xpath": "//input/@*",
    "description": "Select all attributes of input element",
    "category": "attributes"
  },
  {
    "name": "Node type function",
    "html": "<html><body><!-- Comment --><div>Element</div>Text node</body></html>",
    "xpath": "//body/node()",
    "description": "Select all child nodes of body",
    "category": "functions"
  },
  {
    "name": "Count function",
    "html": "<html><body><ul><li>A</li><li>B</li><li>C</li></ul></body></html>",
    "xpath": "//ul[count(li)=3]",
    "description": "Select ul with exactly 3 li children",
    "category": "functions"
  },
  {
    "name": "String length function",
    "html": "<html><body><p>Short</p><p>This is a longer paragraph</p></body></html>",
    "xpath": "//p[string-length(text())>10]",
    "description": "Select paragraphs with text longer than 10 characters",
    "category": "functions"
  },
  {
    "name": "Starts with function",
    "html": "<html><body><a href='https://example.com'>HTTPS</a><a href='http://test.com'>HTTP</a></body></html>",
    "xpath": "//a[starts-with(@href, 'https')]",
    "description": "Select links that start with https",
    "category": "functions"
  },
  {
    "name": "Normalize space function",
    "html": "<html><body><p>  Lots   of    spaces  </p><p>Normal text</p></body></html>",
    "xpath": "//p[normalize-space(text())='Lots of spaces']",
    "description": "Select paragraph after normalizing whitespace",
    "category": "functions"
  },
  {
    "name": "Complex nested structure",
    "html": "<html><body><article><header><h1>Title</h1></header><section><p>Content</p><aside><p>Sidebar</p></aside></section></article></body></html>",
    "xpath": "//article//section//p[not(ancestor::aside)]",
    "description": "Select paragraphs in section but not in aside",
    "category": "complex"
  },
  {
    "name": "Table cell selection",
    "html": "<html><body><table><tr><td>A1</td><td>B1</td></tr><tr><td>A2</td><td>B2</td></tr></table></body></html>",
    "xpath": "//table//tr[2]/td[1]",
    "description": "Select first cell of second row",
    "category": "complex"
  },
  {
    "name": "Form element selection",
    "html": "<html><body><form><input type='text' name='user'/><input type='password' name='pass'/><button type='submit'>Login</button></form></body></html>",
    "xpath": "//form//input[@type='text']",
    "description": "Select text input within form",
    "category": "forms"
  },
  {
    "name": "List with classes",
    "html": "<html><body><ul class='menu'><li class='active'>Home</li><li>About</li><li class='active'>Contact</li></ul></body></html>",
    "xpath": "//ul[@class='menu']/li[@class='active']",
    "description": "Select active menu items",
    "category": "real-world"
  },
  {
    "name": "Navigation breadcrumbs",
    "html": "<html><body><nav><ol><li><a href='/'>Home</a></li><li><a href='/products'>Products</a></li><li>Current Page</li></ol></nav></body></html>",
    "xpath": "//nav//li[not(a)]",
    "description": "Select breadcrumb items without links (current page)",
    "category": "real-world"
  },
  {
    "name": "Data attributes",
    "html": "<html><body><div data-id='123' data-type='product'>Product</div><div data-id='456' data-type='category'>Category</div></body></html>",
    "xpath": "//div[@data-type='product']",
    "description": "Select elements by data attribute",
    "category": "attributes"
  },
  {
    "name": "Empty elements",
    "html": "<html><body><div></div><div>Content</div><div><span></span></div></body></html>",
    "xpath": "//div[not(node())]",
    "description": "Select empty div elements",
    "category": "edge-cases"
  },
  {
    "name": "Multiple classes",
    "html": "<html><body><div class='btn btn-primary btn-large'>Button</div><div class='btn btn-secondary'>Other</div></body></html>",
    "xpath": "//div[contains(@class, 'btn-primary')]",
    "description": "Select element with specific class among multiple classes",
    "category": "attributes"
  }
]