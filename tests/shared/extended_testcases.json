[
  {
    "name": "Descendant-or-self axis",
    "html": "<html><body><div><p>First</p><div><p>Nested</p></div></div></body></html>",
    "xpath": "//div/descendant-or-self::p",
    "description": "Select all p elements that are descendants or the element itself",
    "category": "axes"
  },
  {
    "name": "Ancestor-or-self axis",
    "html": "<html><body><article><section><p id='target'>Content</p></section></article></body></html>",
    "xpath": "//p[@id='target']/ancestor-or-self::*",
    "description": "Select all ancestors including self",
    "category": "axes"
  },
  {
    "name": "Multiple union with predicates",
    "html": "<html><body><h1 class='title'>Header</h1><h2 class='title'>Subheader</h2><h3>Other</h3><p class='title'>Para</p></body></html>",
    "xpath": "//h1[@class='title'] | //h2[@class='title'] | //p[@class='title']",
    "description": "Union of multiple elements with same predicate",
    "category": "union"
  },
  {
    "name": "Complex nested filters",
    "html": "<html><body><div class='container'><article><div class='content'><p>Target</p></div></article><aside><div class='content'><p>Skip</p></div></aside></div></body></html>",
    "xpath": "//div[@class='container']//article//p[ancestor::div[@class='content']]",
    "description": "Complex nested filters with ancestor checking",
    "category": "complex"
  },
  {
    "name": "Attribute value contains",
    "html": "<html><body><div class='btn btn-primary large'>Button 1</div><div class='btn-secondary'>Button 2</div><div class='btn btn-danger'>Button 3</div></body></html>",
    "xpath": "//div[contains(@class, 'btn') and contains(@class, 'primary')]",
    "description": "Multiple contains conditions on same attribute",
    "category": "attributes"
  },
  {
    "name": "Position with conditions",
    "html": "<html><body><ul><li class='item'>A</li><li>B</li><li class='item'>C</li><li class='item'>D</li><li>E</li></ul></body></html>",
    "xpath": "//li[@class='item'][position()=2]",
    "description": "Position among filtered elements",
    "category": "position"
  },
  {
    "name": "Last with conditions",
    "html": "<html><body><div><p class='para'>First</p><span>Middle</span><p class='para'>Last</p></div></body></html>",
    "xpath": "//p[@class='para'][last()]",
    "description": "Last element among filtered results",
    "category": "position"
  },
  {
    "name": "Text nodes selection",
    "html": "<html><body><div>Before<span>Middle</span>After</div></body></html>",
    "xpath": "//div/text()",
    "description": "Select only text nodes",
    "category": "text"
  },
  {
    "name": "Mixed content navigation",
    "html": "<html><body><!-- Comment --><div>Element</div>Text node<p>Paragraph</p></body></html>",
    "xpath": "//body/node()[position()=2]",
    "description": "Navigate mixed content by position",
    "category": "mixed-content"
  },
  {
    "name": "Complex boolean logic",
    "html": "<html><body><div id='a' class='x'>A</div><div id='b' class='y'>B</div><div id='c' class='x y'>C</div><div class='x'>D</div></body></html>",
    "xpath": "//div[(@id='a' or @id='c') and contains(@class, 'x')]",
    "description": "Complex OR and AND combinations",
    "category": "boolean"
  },
  {
    "name": "String functions combination",
    "html": "<html><body><p>  Hello World  </p><p>Short</p><p>  Very long content here  </p></body></html>",
    "xpath": "//p[string-length(normalize-space(text())) > 10]",
    "description": "Combine string-length and normalize-space",
    "category": "functions"
  },
  {
    "name": "Attribute comparison",
    "html": "<html><body><input type='text' maxlength='10'/><input type='password' maxlength='20'/><input type='email'/></body></html>",
    "xpath": "//input[@maxlength and string-length(@maxlength)=2]",
    "description": "Attribute existence and length comparison",
    "category": "attributes"
  },
  {
    "name": "Sibling navigation complex",
    "html": "<html><body><nav><a href='#'>Link1</a><span>Separator</span><a href='#'>Link2</a><div>Other</div><a href='#'>Link3</a></nav></body></html>",
    "xpath": "//span[following-sibling::a and preceding-sibling::a]",
    "description": "Element with both following and preceding siblings",
    "category": "axes"
  },
  {
    "name": "Deep nesting with filters",
    "html": "<html><body><div class='l1'><div class='l2'><div class='l3'><div class='l4'><p>Deep</p></div></div></div></div></body></html>",
    "xpath": "//div[@class='l1']//div[@class='l3']//p",
    "description": "Deep nesting with intermediate filters",
    "category": "complex"
  },
  {
    "name": "Multiple attribute predicates",
    "html": "<html><body><button type='submit' class='btn' disabled>Submit</button><button type='button' class='btn'>Cancel</button><input type='submit' class='btn'/></body></html>",
    "xpath": "//button[@type='submit'][@class='btn'][@disabled]",
    "description": "Multiple consecutive attribute predicates",
    "category": "attributes"
  },
  {
    "name": "Namespace-like attributes",
    "html": "<html><body><div data-id='123' data-type='product' aria-label='Product'>Content</div><div data-id='456' data-type='category'>Other</div></body></html>",
    "xpath": "//div[starts-with(@data-id, '1') and @data-type='product']",
    "description": "Namespace-like attribute handling",
    "category": "attributes"
  },
  {
    "name": "Complex table navigation",
    "html": "<html><body><table><thead><tr><th>Name</th><th>Age</th></tr></thead><tbody><tr><td>John</td><td>25</td></tr><tr><td>Jane</td><td>30</td></tr></tbody></table></body></html>",
    "xpath": "//tbody/tr[position()>1]/td[position()=1]",
    "description": "Navigate table with position filters",
    "category": "tables"
  },
  {
    "name": "Form elements with states",
    "html": "<html><body><form><input type='text' name='user' required/><input type='email' name='email'/><input type='password' name='pass' required/><button type='submit'>Submit</button></form></body></html>",
    "xpath": "//form//input[@required]/following-sibling::input[@required]",
    "description": "Navigate between required form elements",
    "category": "forms"
  },
  {
    "name": "List with mixed content",
    "html": "<html><body><ul><li><span>Item 1</span><!-- comment --></li><li>Item 2</li><li><a href='#'>Item 3</a><span>Extra</span></li></ul></body></html>",
    "xpath": "//li[span and not(a)]",
    "description": "List items with specific child combinations",
    "category": "lists"
  },
  {
    "name": "Conditional text content",
    "html": "<html><body><div><p>Paragraph 1</p></div><div><span>Span text</span></div><div><p>Paragraph 2</p><span>Extra</span></div></body></html>",
    "xpath": "//div[p and not(span)]/p",
    "description": "Conditional selection based on sibling presence",
    "category": "conditional"
  },
  {
    "name": "Attribute with special characters",
    "html": "<html><body><div data-value='hello-world_123'>Test</div><div data-value='other.value'>Other</div></body></html>",
    "xpath": "//div[contains(@data-value, '-') and contains(@data-value, '_')]",
    "description": "Attributes with hyphens and underscores",
    "category": "attributes"
  },
  {
    "name": "Empty vs non-empty elements",
    "html": "<html><body><div></div><div> </div><div><span></span></div><div>Content</div></body></html>",
    "xpath": "//div[normalize-space(text())='' and not(*)]",
    "description": "Distinguish empty vs whitespace-only elements",
    "category": "edge-cases"
  },
  {
    "name": "Complex ancestor checking",
    "html": "<html><body><main><article><section class='content'><div><p class='text'>Target</p></div></section></article><aside><section class='sidebar'><div><p class='text'>Skip</p></div></section></aside></main></body></html>",
    "xpath": "//p[@class='text'][ancestor::section[@class='content']]",
    "description": "Ancestor checking with specific class",
    "category": "axes"
  },
  {
    "name": "Multiple text conditions",
    "html": "<html><body><p>Hello World</p><p>Hello Universe</p><p>Goodbye World</p><p>Hello</p></body></html>",
    "xpath": "//p[starts-with(text(), 'Hello') and contains(text(), 'World')]",
    "description": "Multiple text function conditions",
    "category": "text"
  },
  {
    "name": "Position in filtered set",
    "html": "<html><body><div><span class='item'>A</span><p>X</p><span class='item'>B</span><div>Y</div><span class='item'>C</span><span class='item'>D</span></div></body></html>",
    "xpath": "//span[@class='item'][position() mod 2 = 0]",
    "description": "Even positions in filtered set",
    "category": "position"
  },
  {
    "name": "Mixed axis navigation",
